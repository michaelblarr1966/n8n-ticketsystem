    {
      "parameters": {
        "functionCode": "const text = ($json.message || '').toLowerCase();\n\nlet category = 'Allgemein';\nlet team = 'Support';\nlet priority = 'Normal';\n\nif (/login|passwort|anmeldung|zugang/.test(text)) {\n  category = 'Login';\n  team = 'Support';\n} else if (/lieferung|versand|tracking|paket/.test(text)) {\n  category = 'Lieferung';\n  team = 'Logistik';\n} else if (/zahlung|rechnung|paypal|kreditkarte/.test(text)) {\n  category = 'Zahlung';\n  team = 'Buchhaltung';\n}\n\nif (/dringend|sofort|kritisch|ausfall/.test(text)) priority = 'High';\nif (/system down|komplett down|totalausfall/.test(text)) priority = 'Critical';\n\nconst now = new Date();\nconst pad = (n) => String(n).padStart(2, '0');\nconst ms = String(now.getMilliseconds()).padStart(3, '0');\nconst ticketId = `TCK-${now.getFullYear()}${pad(now.getMonth()+1)}${pad(now.getDate())}-${pad(now.getHours())}${pad(now.getMinutes())}${pad(now.getSeconds())}-${ms}`;\n\nreturn [{\n  json: {\n    ...$json,\n    ticket_id: ticketId,\n    category,\n    team,\n    priority,\n    status: 'open',\n    created_at: now.toISOString(),\n    updated_at: now.toISOString()\n  }\n}];\n"
      },
      "id": "bc29ccc9-5370-42b0-b339-6252d61ea75c",
