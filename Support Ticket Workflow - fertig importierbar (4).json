    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const subject = $json.subject ?? '';\n\nconst html = $json.html ?? '';\nconst text = $json.textPlain ?? $json.text ?? '';\n\nconst fromEmail = $json.from.value[0].address ??'';\nconst fromName = $json.from.value[0].name ?? '';\n\n\n\nconst body = String(text || html || '')\n  .replace(/<[^>]*>/g, ' ')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\nconst messageId =\n  $json.messageId ??\n  $json.headers?.['message-id'] ??\n  $json.metadata?.['message-id'] ??\n  $json.headers?.['Message-ID'] ??\n  $json.message_id ??\n  '';\n\n// Ticket-ID aus Subject + Body extrahieren\nconst content = `${subject} ${body}`;\nconst ticketMatch = content.match(/TCK-\\d{8}-\\d{6}-\\d+/i);\nconst ticketId = ticketMatch ? ticketMatch[0] : null;\n\nreturn {\n  subject,\n  body,\n  html,\n  text,\n  fromEmail,\n  fromName,\n  messageId,\n  ticketId,\n};"
      },
